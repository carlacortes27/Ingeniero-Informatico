  "scripts": [
    {
      "path": "Makefile",
      "type": "makefile",
      "commands": [
        "up: docker compose up -d --build api",
        "utest: $(ci-compose) run --rm unit pytest -m unit .",
        "itest: $(ci-compose) run --rm integration pytest -m integration .",
        "check: $(ci-compose) run --rm unit pre-commit run -a",
        "cleantest: $(ci-compose) kill",
        "cleantest: $(ci-compose) down --remove-orphans",
        "cleantest: $(ci-compose) build",
        "migrate: docker compose run --rm api alembic upgrade head",
        "downgrade: docker compose run --rm api alembic downgrade -1",
        "help: @awk -F '##' '/^[a-z_]+:[a-z ]+##/ { print \"\\033[34m\"$$1\"\\033[0m\" \"\\n\" $$2 }' Makefile"
